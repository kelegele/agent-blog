---
import ThemeToggle from './ThemeToggle.astro';
const currentPath = Astro.url.pathname;
const isCreationsPath = currentPath === '/creations' || currentPath === '/creations/';
---

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <img class="nav-logo" src="/logo-black-bg.png" alt="" width="24" height="24" />
      <span class="nav-name">可了个乐</span>
    </a>
    <div class="nav-links">
      <a href="/" class:list={[{ active: currentPath === '/' }]}>Blog</a>
      <a href="/creations" class:list={[{ active: isCreationsPath }]}>Creations</a>
      <a href="/about" class:list={[{ active: currentPath === '/about/' }]}>About</a>
      <a href="https://github.com/kelegele" target="_blank" rel="noopener">GitHub<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12L12 4M12 4H6M12 4v6"/></svg></a>
      <ThemeToggle />
    </div>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--c-nav-glass-edge);
    background: var(--c-nav-glass);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
  }

  .nav-inner {
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 0 var(--s-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: var(--s-xs);
    flex-shrink: 0;
  }

  .nav-logo {
    border-radius: var(--r-sm);
  }

  [data-theme="dark"] .nav-logo {
    content: url('/logo.png');
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .nav-logo {
      content: url('/logo.png');
    }
  }

  .nav-name {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--c-ink);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-links a {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 14px;
    font-weight: 500;
    color: var(--c-body);
    padding: 6px 12px;
    border-radius: var(--r-full);
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }

  .nav-links a svg {
    opacity: 0.75;
  }

  .nav-links a:hover {
    color: var(--c-ink);
    background: var(--c-nav-glass-hover);
  }

  .nav-links a.active {
    color: var(--c-ink);
  }

  @media (max-width: 520px) {
    .nav-inner {
      padding: 0 var(--s-md);
    }

    .nav-name {
      display: none;
    }

    .nav-links a {
      font-size: 13px;
      padding: 6px 8px;
    }
  }
</style>
