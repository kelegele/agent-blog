---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const slugs = [...new Set(allPosts.map(p => p.data.categorySlug || p.data.category))];
  return slugs.map(cat => ({ params: { cat } }));
}

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const { cat } = Astro.params;
const filteredPosts = allPosts.filter(p => (p.data.categorySlug || p.data.category) === cat);

const categoryMap = Object.fromEntries(
  allPosts.map(p => [p.data.categorySlug || p.data.category, p.data.category])
);
const categories = [...new Set(allPosts.map(p => p.data.categorySlug || p.data.category))];
---

<BaseLayout>
  <section class="hero">
    <h1 class="hero-title">可了个乐</h1>
    <p class="hero-subtitle">AI × Creativity</p>
    <p class="hero-desc">用 AI 探索创造的无限可能</p>
  </section>

  <section class="posts">
    <div class="posts-inner">
      <nav class="cat-nav">
        <a class="cat-link" href="/">全部</a>
        {categories.map((c) => (
          <a class:list={['cat-link', { active: c === cat }]} href={`/category/${c}`}>{categoryMap[c]}</a>
        ))}
      </nav>

      <div class="article-list">
        {filteredPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.id}
          />
        ))}
      </div>

      {filteredPosts.length === 0 && (
        <p class="empty">暂无文章</p>
      )}
    </div>
  </section>
</BaseLayout>

<style is:global>
  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--s-5xl) var(--s-lg) var(--s-3xl);
  }

  .hero-title {
    font-size: 64px;
    font-weight: 600;
    letter-spacing: -3.2px;
    line-height: 64px;
    margin-bottom: var(--s-xs);
    color: var(--c-ink);
    background: var(--g-hero);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.96px;
    line-height: 32px;
    margin-bottom: var(--s-xs);
    color: var(--c-body);
  }

  .hero-desc {
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    color: var(--c-mute);
  }

  .posts-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--s-lg) var(--s-4xl);
  }

  .cat-nav {
    display: flex;
    align-items: center;
    gap: 0;
    padding: var(--s-sm) 0;
    margin-bottom: var(--s-md);
    border-bottom: 1px solid var(--c-hairline);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .cat-nav::-webkit-scrollbar {
    display: none;
  }

  .cat-link {
    flex-shrink: 0;
    display: inline-block;
    font-size: 14px;
    font-weight: 400;
    line-height: 20px;
    color: var(--c-mute);
    text-decoration: none;
    padding: 6px 14px;
    transition: color 0.15s;
  }

  .cat-link:hover {
    color: var(--c-ink);
  }

  .cat-link.active {
    color: var(--c-ink);
    font-weight: 500;
  }

  .empty {
    padding: var(--s-3xl) 0;
    text-align: center;
    color: var(--c-mute);
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--s-3xl) var(--s-lg) var(--s-xl);
    }

    .hero-title {
      font-size: 40px;
      letter-spacing: -1.6px;
      line-height: 48px;
    }

    .hero-subtitle {
      font-size: 18px;
      letter-spacing: -0.6px;
      line-height: 28px;
    }

    .posts-inner {
      padding: 0 var(--s-md) var(--s-3xl);
    }

    .cat-link {
      font-size: 13px;
      padding: 6px 10px;
    }
  }
</style>
