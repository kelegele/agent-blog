---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = ['全部', ...new Set(allPosts.map(p => p.data.category))];
---

<BaseLayout>
  <section class="hero">
    <h1 class="hero-title">可了个乐</h1>
    <p class="hero-subtitle">AI × Creativity</p>
    <p class="hero-desc">用 AI 探索创造的无限可能</p>
  </section>

  <section class="posts">
    <div class="posts-inner">
      <div class="category-bar" id="category-bar">
        {categories.map((cat) => (
          <button
            class:list={['category-pill', { active: cat === '全部' }]}
            data-category={cat}
          >{cat}</button>
        ))}
      </div>

      <div class="article-list">
        {allPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.id}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--s-5xl) var(--s-lg) var(--s-3xl);
  }

  .hero-title {
    font-size: 64px;
    font-weight: 600;
    letter-spacing: -3.2px;
    line-height: 64px;
    margin-bottom: var(--s-xs);
    color: var(--c-ink);
    background: var(--g-hero);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.96px;
    line-height: 32px;
    margin-bottom: var(--s-xs);
    color: var(--c-body);
  }

  .hero-desc {
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    color: var(--c-mute);
  }

  .posts-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--s-lg) var(--s-4xl);
  }

  /* ── Category Bar ──────────────────────── */
  .category-bar {
    display: flex;
    flex-wrap: nowrap;
    gap: 6px;
    overflow-x: auto;
    padding-bottom: var(--s-sm);
    margin-bottom: var(--s-xl);
    border-bottom: 1px solid var(--c-hairline);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .category-bar::-webkit-scrollbar {
    display: none;
  }

  .category-pill {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 400;
    color: var(--c-mute);
    background: none;
    border: none;
    padding: var(--s-xs) var(--s-sm);
    border-radius: var(--r-full);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    line-height: 20px;
  }

  .category-pill:hover {
    color: var(--c-ink);
  }

  .category-pill.active {
    color: var(--c-ink);
    background: var(--c-canvas-soft);
  }

  .article-card-hidden {
    display: none;
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--s-3xl) var(--s-lg) var(--s-xl);
    }

    .hero-title {
      font-size: 40px;
      letter-spacing: -1.6px;
      line-height: 48px;
    }

    .hero-subtitle {
      font-size: 18px;
      letter-spacing: -0.6px;
      line-height: 28px;
    }

    .posts-inner {
      padding: 0 var(--s-md) var(--s-3xl);
    }

    .category-bar {
      margin-bottom: var(--s-lg);
    }
  }
</style>

<script>
  const bar = document.getElementById('category-bar');
  const cards = document.querySelectorAll<HTMLElement>('.article-card');

  bar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.category-pill');
    if (!btn) return;

    // Toggle active pill
    bar.querySelectorAll('.category-pill').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    const cat = btn.dataset.category;
    cards.forEach(card => {
      const cardCat = (card as HTMLElement).dataset.category;
      card.classList.toggle('article-card-hidden', cat !== '全部' && cardCat !== cat);
    });
  });
</script>
