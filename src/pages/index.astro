---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [...new Set(allPosts.map(p => p.data.category))];
---

<BaseLayout>
  <section class="hero">
    <h1 class="hero-title">可了个乐</h1>
    <p class="hero-subtitle">AI × Creativity</p>
    <p class="hero-desc">用 AI 探索创造的无限可能</p>
  </section>

  <section class="posts">
    <div class="posts-inner">
      <nav class="category-nav">
        <button class="cat-link active" data-category="">全部</button>
        {categories.map((cat) => (
          <button class="cat-link" data-category={cat}>{cat}</button>
        ))}
      </nav>

      <div class="article-list">
        {allPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.id}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--s-5xl) var(--s-lg) var(--s-3xl);
  }

  .hero-title {
    font-size: 64px;
    font-weight: 600;
    letter-spacing: -3.2px;
    line-height: 64px;
    margin-bottom: var(--s-xs);
    color: var(--c-ink);
    background: var(--g-hero);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.96px;
    line-height: 32px;
    margin-bottom: var(--s-xs);
    color: var(--c-body);
  }

  .hero-desc {
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    color: var(--c-mute);
  }

  .posts-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--s-lg) var(--s-4xl);
  }

  /* ── Category Nav (Vercel Blog style) ──── */
  .category-nav {
    display: flex;
    align-items: center;
    gap: 0;
    border-bottom: 1px solid var(--c-hairline);
    padding-bottom: 0;
    margin-bottom: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .category-nav::-webkit-scrollbar {
    display: none;
  }

  .cat-link {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    line-height: 20px;
    color: var(--c-mute);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 12px 16px;
    cursor: pointer;
    transition: color 0.15s;
    position: relative;
  }

  .cat-link:hover {
    color: var(--c-ink);
  }

  .cat-link.active {
    color: var(--c-ink);
    font-weight: 500;
    border-bottom-color: var(--c-ink);
  }

  [data-theme="dark"] .cat-link.active {
    border-bottom-color: var(--c-ink);
  }

  /* ── Article hidden state ──────────────── */
  .article-card-hidden {
    display: none;
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--s-3xl) var(--s-lg) var(--s-xl);
    }

    .hero-title {
      font-size: 40px;
      letter-spacing: -1.6px;
      line-height: 48px;
    }

    .hero-subtitle {
      font-size: 18px;
      letter-spacing: -0.6px;
      line-height: 28px;
    }

    .posts-inner {
      padding: 0 var(--s-md) var(--s-3xl);
    }

    .cat-link {
      font-size: 13px;
      padding: 10px 12px;
    }
  }
</style>

<script>
  const nav = document.querySelector('.category-nav');
  const cards = document.querySelectorAll<HTMLElement>('.article-card');

  nav?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.cat-link');
    if (!btn) return;

    nav.querySelectorAll('.cat-link').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    const cat = btn.dataset.category;
    cards.forEach(card => {
      const cardCat = card.dataset.category;
      card.classList.toggle('article-card-hidden', cat !== '' && cardCat !== cat);
    });
  });
</script>
